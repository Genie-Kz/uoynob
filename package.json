{
  "name": "bonyou-iruruka-sp",
  "version": "1.0.0",
  "description": "凡庸な イルルカSP（クライアントサイド再現版） - Vue 3 + TypeScript + Vite + Tailwind",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:actions": "actionlint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run format:check && npm run lint:actions && npm run test && npm run build",
    "test": "vitest run --project unit",
    "test:coverage": "vitest run --project unit --coverage",
    "test:e2e": "playwright test",
    "test:storybook": "vitest run --project storybook",
    "test:all": "npm run test && npm run test:e2e",
    "test:watch": "vitest --project unit",
    "prepare": "simple-git-hooks",
    "data:monsters": "node scripts/build-data.js",
    "data:skills": "node scripts/scrape-skills.js",
    "data:traits-abilities": "node scripts/scrape-traits-abilities.js",
    "data:pickups": "node scripts/scrape-pickups.js",
    "data:icons": "node scripts/scrape-monster-icons.js",
    "data:icons-webp": "node scripts/convert-icons-webp.js",
    "data:readings": "node scripts/build-search-readings.js",
    "data:monster-list": "node scripts/build-monster-list.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "commit-msg": "npx --no-install commitlint --edit $1",
    "pre-push": "npm run lint:actions"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "sharp": "^0.35.1",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.4",
    "storybook": "^10.4.6",
    "@storybook/vue3-vite": "^10.4.6",
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-onboarding": "^10.4.6",
    "eslint-plugin-storybook": "^10.4.6",
    "playwright": "^1.61.0",
    "@vitest/browser-playwright": "^4.1.8"
  }
}
